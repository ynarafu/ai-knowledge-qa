# どのLLMバックエンドを使うか: "mock" | "ollama" | "claude"
# - mock   … 鍵不要・サンプル応答。Vercel公開用の既定
# - ollama … ローカルのOllamaで本物のAIを動かす（録画用）
# - claude … Claude APIを使う（ANTHROPIC_API_KEYが必要）
LLM_PROVIDER=mock

# Ollama 設定（LLM_PROVIDER=ollama のとき）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Claude 設定（LLM_PROVIDER=claude のとき）
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
